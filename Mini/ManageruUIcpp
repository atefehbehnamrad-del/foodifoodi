#include "ManagerUI.h"
#include "Food.h"
#include "Drink.h"
#include "Other.h"
#include <iostream>
#include <limits>

using namespace std;

static int readInt(const string& prompt) {
    int val;
    while (true) {
        cout << prompt;
        if (cin >> val) {
            cin.ignore(numeric_limits<streamsize>::max(), '\n');
            return val;
        }
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "Error:enter the number again." << endl;
    }
}

ManagerUI::ManagerUI(RestaurantManager& user, RestaurantDAO& rDAO, MenuItemDAO& mDAO, OrderDAO& oDAO)
    : user_(user), rDAO_(rDAO), mDAO_(mDAO), oDAO_(oDAO),rId_(user.getRestaurantId()) {}

void ManagerUI::run() {
    while (true) {
        user_.showMenu();
        int choice = readInt("");

        if      (choice == 0) break;
        else if (choice == 1) editRestaurantInfo();
        else if (choice == 2) manageMenu();
        else if (choice == 3) manageOrders();
        else cout << "Error:please chouce number between 0 _ 3" endl;
    }
}

void ManagerUI::editRestaurantInfo() {
    Restaurant* r = rDAO_.getRestaurantById(rId_);
    if (!r) { cout << "Restaurant dint find ;0" << endl; 
        return;}

    r->display();

    int ch = readInt("1.return 0.Edit information \nchoice: ");
    if (ch == 1) {
        cout << "نام جدید: ";    string name;  getline(cin, name);
        cout << "آدرس جدید: ";   string addr;  getline(cin, addr);
        cout << "تلفن جدید: ";   string phone; getline(cin, phone);
        cout << "توضیحات: ";     string desc;  getline(cin, desc);
        int prep = readInt("Prepare time(min): ");

        r->setName(name);
        r->setAddress(addr);
        r->setPhone(phone);
        r->setDescription(desc);
        r->setPrepare(prep);
        rDAO_.updateRestaurant(*r);
        cout << "infor mation updated" << endl;
    }
    delete r;
}

void ManagerUI::manageMenu() {
    vector<MenuItem*> items = mDAO_.getItemsByRestaurant(rId_);

    cout << "\n_____New menu_____\n" << endl;
    if (items.empty()){
    cout << "Menu is empty;0" << endl;
    }else for (auto* item : items) item->display();

    cout << "1. Add item" << endl;
    cout << "2. Edit price" << endl;
    cout << "3. Change status" << endl;
    cout << "4. Remove item" << endl;
    cout << "0. Return" << endl;
    int ch = readInt("choice:");

    if (ch == 1) {
        cout << "Name: ";     string name; getline(cin, name);
        cout << "Description: ";   string desc; getline(cin, desc);
        double price;
        cout << " ";    cin >> price; cin.ignore();
        int type = readInt("(1.food 2.Drink 3.Other) type: ");

        int newId = items.empty() ? 1 : items.back()->getId() + 1;

        MenuItem* newItem = nullptr;
        if (type == 1) {
            int rt = readInt("Ready time(min)");
            newItem = new Food(newId, name, desc, price, true, rt);
        } else if (type == 2) {
            int cap = readInt("Capacity(mL): ");
            newItem = new Drink(newId, name, desc, price, true, cap);
        } else {
            cout << "Group"; string cat; getline(cin, cat);
            newItem = new Other(newId, name, desc, price, true, cat);
        }

        if (newItem) {
            mDAO_.insertMenuItem(*newItem, rId_);
            cout << "item added" << endl;
            delete newItem;
        }

    } else if (ch == 2) {
        int itemId = readInt("item ID: ");
        double newPrice;
        cout << "new price: "; cin >> newPrice; cin.ignore();
        for (auto* item : items) {
            if (item->getId() == itemId) {
                item->setPrice(newPrice);
                mDAO_.updateMenuItem(*item);
                cout << "price updated" << endl;
                break;
            }
        }

    } else if (ch == 3) {
        int itemId = readInt("item ID: ");
        for (auto* item : items) {
            if (item->getId() == itemId) {
                item->setAvailability(!item->isAvailable());
                mDAO_.updateMenuItem(*item);
                cout << "status" << (item->isAvailable() ? "available" : "unavailable")
                     << "updated" << endl;
                break;
            }
        }

    } else if (ch == 4) {
        int itemId = readInt("Item ID for deleting: ");
        mDAO_.deleteMenuItem(itemId);
        cout << "item deleted" << endl;
    }

    for (auto* item : items) delete item;
}

void ManagerUI::manageOrders() {
    vector<Order> orders = oDAO_.getOrdersByRestaurant(rId_);
    if (orders.empty()) {
        cout << "No order is here." << endl;
        return;
    }

    cout << "\n_____Order_____\n" << endl;
    for (auto& order : orders) order.display();

    int orderId = readInt("item ID for status (0 return): ");
    if (orderId == 0) return;

    cout << "1. preparing" << endl;
    cout << "2. ready for send" << endl;
    cout << "3. delivered" << endl;
    int s = readInt("choice: ");

    OrderStatus newStatus;
    if      (s == 1) newStatus = OrderStatus::PREPARING;
    else if (s == 2) newStatus = OrderStatus::READY_TO_SEND;
    else if (s == 3) newStatus = OrderStatus::DELIVERED;
    else { cout << "Error:choose the number between 1-3 ." << endl;
           return; }

    oDAO_.updateOrderStatus(orderId, newStatus);
    cout << "Status updated." << endlss;
}